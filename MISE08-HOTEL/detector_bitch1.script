dim_flt 2
dim_act 2 
dim_frm 2
findactor 0,"Bitch"
findactor 1,"Bitch2"

findframe 0,"Bitch"
findframe 1,"Bitch2"

act_setstate -1,inactive

label 1
wait 500
detector_inrange 0, 1
if flt[0]=1, -1, 1

rnd 1,2

if flt[1] = 0 ,-1, 4
act_setstate 0, active
frm_seton  0, 1
setevent 0, 1, 1
end

Label 4
act_setstate 1, active
frm_seton  1, 1
setevent 1, 1, 1
end

