dim_flt 1
dim_act 2
findactor 0
findactor 1, "Tommy"

enemy_playanim "Mise03a Frank stativ.I3D"

label LOOKRANDOM
gosub WAIT
getactorsdist 0, 1, 0
if flt[0] < 10, CUM, NECUM

label CUM
human_looktoactor 0, 1, 1
goto LOOKRANDOM

label NECUM
human_looktoactor 0
goto LOOKRANDOM

label WAIT
rnd 0, 5
let flt[0] = flt[0] + 1
let flt[0] = flt[0] * 1200
wait flt[0]
return