event_use_cb 1
let flt[1] = 6
return

event USE_AB, 18970001
   human_eraseab 0
   debug_text "Organizator: EVENT AB"
   if flt[1] = 4, RET, -1
      gosub ACTION
      if flt[1] = 1, ZECHCIJE, -1
      if flt[1] = 2, ZECHCIJE, -1
      human_createab 0
      event_use_cb 0
   return

   label ZECHCIJE
      let flt[5] = 1
      human_createab 0
      event_use_cb 0
  return

   label RET
      let flt[5] = 1
      event_use_cb 1
      enemy_forcescript 0
   return


label FINISH
commandblock 0
enemy_look 1
enemy_wait
debug_text "Organizator: SCRIPT FINISHED"