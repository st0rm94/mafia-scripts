label CHECKLIFE
human_getproperty 1, 0, Energy
if flt[0] = 0, FINISH, -1
// flt[6] = jestli hrac nahodou nemluvi s borcama co mu maji pomoct nosit bedny
if flt[6] = 1, CHECKLIFE, -1
// flt[7] = jestli hrac nahodou nemluvi s borcama co odjedou v nakladaku
if flt[7] = 1, CHECKLIFE, -1
// flt[8] = jestli hrac nahodou nemluvi s borcama u vlaku
