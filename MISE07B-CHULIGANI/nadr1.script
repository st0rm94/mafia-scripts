///nahodny nadr1

dim_flt 2
dim_frm 1
FindFrame 0

frm_seton 0, 0
label 10
  let flt[1] = 0
  rnd 0, 9                   
  let flt[0] = flt[0] * 5000 
  let flt[0] = flt[0] + 20000
  wait flt[0]
  rnd 0, 9
  let flt[0] = flt[0] + 3
  let flt[0] = flt[0] * 2738

  soundfade 0, 2000, 0, 1
  wait flt[0]
  soundfade 0, 2000, 1, 0
goto 10