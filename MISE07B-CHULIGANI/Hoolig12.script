enemy_vidim 0
dim_act 1
dim_flt 1
dim_frm 1
findactor 0
findframe 0, "17_creak"
human_addweapon 0, 25, 0, 0
act_setstate -1, inactive

{ DOWN
label FREESTATE
enemy_playanim "PaceniDveri.I3d", 0
let flt[0] = flt[0] - 250
let flt[0] = flt[0] / 2
wait flt[0]
frm_seton 0, 1
wait flt[0]
