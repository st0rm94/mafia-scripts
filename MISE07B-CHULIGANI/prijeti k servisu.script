act_setstate 19, active
act_setstate 20, active
act_setstate 21, active
act_setstate 22, active
act_setstate 23, active
debug_text "prijeti k servisu: actors active!"

label HLASKY
wait 200
gosub CHECKSVESTKY
getactorsdist 2, 15, 0
if flt[0] > 30, PREJEL, -1
if flt[0] < 10, -1, HLASKY
human_looktoactor 2, 0, 1
if flt[1] ! 1, -1, SERVICEPRIJEZD
human_talk 2, 07990481, 1
let flt[1] = 1

label SERVICEPRIJEZD
compareownerwithex 2, 16, -1, HLASKY
enemy_forcescript 2
end

label PREJEL
compareownerwithex 0, 16, HLASKY, -1
rnd 0, 4
let flt[0] = flt[0]  + 1
if flt[2] = flt[0], PREJEL, -1
goto flt[0]
label 1
human_talk 2, 950042, 1
goto RET
label 2
human_talk 2, 950043, 2
goto RET
label 3
human_talk 2, 950044, 2
goto RET
label 4
human_talk 2, 950045, 2
label RET
let flt[2] = flt[0]
wait 10000
goto HLASKY

label CHECKSVESTKY
//vlvp 0
//if flt[0] ! 0, -1, RET3
//policeitchforplayer 0
//if flt[0] ! 0, -1, RET3
get_pm_numpredators 0, 0
if flt[0] ! 0, -1, RET3
debug_text "Prijeti k servisu: SVESTKY PO NAS JDOU"
gosub SVESTKY
goto CHECKSVESTKY
label RET3
debug_text "Prijeti k servisu:  SVESTKY PO NAS NEJDOU"
return

label SVESTKY
// Paulie 950072-74
getactorsdist 0, 2, 0
if flt[0] > 10, TOMMY, -1
rnd 0, 3
let flt[0] = flt[0] + 5
if flt[2] = flt[0], SVESTKY, -1
goto flt[0]
label 5
human_talk 2, 950072 ,2
goto RET2
label 6
human_talk 2, 950073 ,2
goto RET2
label 7
