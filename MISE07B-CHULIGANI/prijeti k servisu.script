findactor 21, "civil"
findactor 22, "Hoolig3"
findactor 23, "Hoolig4"

//Vypinam se - zapne mne az Biff
act_setstate -1, inactive

//Kdyz prijedou k servisu
LABEL DETECT
wait 200
detector_inrange 0,18
if flt[0] = 1,-1, DETECT
door_lock 8, 0
act_setstate 1, active
act_setstate 3, active
act_setstate 4, active
act_setstate 5, active
// Zapina mne Paulie kvuli sejvu
//act_setstate 6, active
act_setstate 7, active
act_setstate 9, active
act_setstate 10, active
