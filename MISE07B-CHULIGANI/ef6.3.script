// zapne mne az prijeti k servisu
act_setstate -1, inactive
///////////////////////////ef6.3

DIM_FRM 2
DIM_FLT 2

FINDFRAME 0, "ef6.3"
FINDFRAME 1, "ef7.3"

label 1
  rnd 0, 6  
  let flt[0] = flt[0] * 6800 
  let flt[0] = flt[0] + 13800
  wait flt[0]
 rnd 1, 8
 IFFLTINRANGE 1, 0, 3, 2
 IFFLTINRANGE 1, 4, 7, 3

label 2
 FRM_SETON 0, 1
goto 1

label 3
 FRM_SETON 1, 1
goto 1