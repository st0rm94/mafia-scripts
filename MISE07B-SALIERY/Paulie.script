event_use_cb 0
return

event 3
//event ze player uz visel ze zasedacky
event_use_cb 0
let flt[5] = 1
return

event 100
// event Vincenzo dialog start
let flt[1] = 10
event_use_cb 1
enemy_forcescript 1
return

label HLASKA
rnd 0, 3
let flt[0] = flt[0] +1
if flt[0] = 1, HLASKA1, -1
if flt[0] = 2, HLASKA2, -1
if flt[0] = 3, HLASKA3, HLASKA4
label HLASKA1
enemy_talk 1, 00950009, 1
enemy_wait
return
label HLASKA2
enemy_talk 1, 00950010, 1
enemy_wait
return
label HLASKA3
enemy_talk 1, 00950011, 1
enemy_wait
return
label HLASKA4
enemy_talk 1, 00950012, 1
enemy_wait
return

event USE_AB, 07970005
//#############
//#   EVENT AB  ##
//#############
human_eraseab 1
event_use_cb 0
human_looktoactor 0, 1, 1
label RERAND
rnd 0, 4
let flt[0] = flt[0] + 13
if flt[3] = flt[0], RERAND, -1
goto flt[0]
label 13
enemy_talk 1, 00950026
goto RET
label 14
enemy_talk 1, 00950027
goto RET
label 15
enemy_talk 1, 00950028
goto RET
label 16
enemy_talk 1, 00950029
goto RET
label 17
enemy_talk 1, 00950030
label RET
human_looktoactor 0
let flt[3] = flt[0]
human_createab 1
return

event HIT_FROM_PLAYER
if flt[4] > 4, RET2, -1
human_looktoactor 1, 2, 1
let flt[4] = flt[4] +1
human_stoptalk 1
human_getproperty 1, 0, Energy
if flt[0] < 40, NASERSE, -1
if flt[4] = 1, 18, -1
if flt[4] = 2, 19, -1
if flt[4] = 3, 20, NASERSE
label 18
enemy_talk 00950094
goto RET2
label 19
enemy_talk 00950095
goto RET2
label 20
enemy_talk 00950096
goto RET2
label NASERSE
enemy_shut_up no
human_looktoactor 1
enemy_vidim 1
enemy_naserse 2
label RET2
event_use_cb 0
return

event 1000
enemy_shut_up no
enemy_vidim 1
setaipriority 100
return

label FINISH
debug_text "Paulie: SCRIPT FINISHED !!!"