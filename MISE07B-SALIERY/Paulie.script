LABEL FOLLOW
{ DOWN
enemy_action_follow 2,3, NONEXT, target, 4
}
goto FOLLOW

event 1
event_use_cb 1
let flt[1] = 2
return

event 2
//debug_text "Mam event ze Vincenzo uz vstal ze zidle!"
