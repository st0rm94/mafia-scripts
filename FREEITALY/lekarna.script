dim_act 1
dim_flt 1
findactor 0,"Tommy"

label 101
detector_waitforuse 08970005
human_getproperty 0,0,Energy
if flt[0]=100,101,-1
freeride_scoreget 0
if flt[0]<1000,MALOPENEZ,-1
let flt[0]=flt[0]-1000
freeride_scoreset flt[0]
human_setproperty 0,100,Energy
goto 101



label MALOPENEZ
console_addtext 3472
goto 101