dim_act 1
dim_flt 1
findactor 0,"Tommy"

label 101
detector_waitforuse 3512
human_canaddweapon 0,12,0
if flt[0]=1,-1,NENIMISTO

freeride_scoreget 0
if flt[0]<500,MALOPENEZ,-1
let flt[0]=flt[0]-500
freeride_scoreset flt[0]
human_addweapon 0,12,2,22
goto 101



label MALOPENEZ
console_addtext 3472
goto 101

label NENIMISTO
console_addtext 3473
goto 101
