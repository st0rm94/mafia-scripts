dim_flt 2
dim_act 3
findactor 0, "Kasar2"
findactor 1, "Tommy"
findactor 2, "NULL"

label 1
wait 100
detector_inrange 0, 30
if flt[0] = 1, -1, 1
human_getowner 1, 2
car_getspeed 2, 1
if flt[1] = 0, -1, 1
setevent 0, 1, 3
detector_setsignal -1, 1
end

