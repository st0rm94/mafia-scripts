commandblock 1
dim_flt 4
dim_frm 2
dim_act 3
findactor 0, ""
findactor 1, "TommySAILOR"
findactor 2, "waiter"
findframe 0, "2sklinka10"
findframe 1, "2sklinka11"
frm_seton 1, 0
frm_seton 0, 1
commandblock 0

label 1
enemy_playanim "x bar stojak stativ01.i3d"
wait 8000
let flt[1] = 1
enemy_playanim "x bar stojak piti01.i3d", 0
wait 900
frm_seton 0, 0
frm_seton 1, 1
wait 5000
frm_seton 0, 1
frm_seton 1, 0
wait 2100
let flt[1] = 0
