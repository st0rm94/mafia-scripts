event use_ab, 14970002
getenemyaistate 0, 2
if flt[2] ! 0, 6, -1
if flt[1] = 1, 6, -1
human_looktoactor 0, 1, 1
if flt[3] = 0, 2, -1
enemy_talk 14950017
let flt[3] = 0
goto 6
label 2
