dim_flt 1
dim_act 3
findactor 0, "TommySAILOR"
findactor 1, "Bguard"
findactor 2, "Bguard2"

label 1
wait 100
DETECTOR_INRANGE 0, 3
if flt[0] = 1, -1, 1
human_looktoactor 1, 0, 1
wait 250
human_looktoactor 2, 0, 1
label 2
wait 100
DETECTOR_INRANGE 0, 3
if flt[0] = 0, -1, 2
human_looktoactor 2
wait 250
human_looktoactor 1
goto 1
