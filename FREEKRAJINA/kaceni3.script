//kaceni stromu 2

DIM_FRM 2
DIM_FLT 2

FINDFRAME 0, "sekera2"
FINDFRAME 1, "strom3"

label 1
  rnd 0, 8  
  let flt[0] = flt[0] * 2000
  let flt[0] = flt[0] + 8000
  wait flt[0]
 rnd 1, 10
 IFFLTINRANGE 1, 0, 7, 2
 IFFLTINRANGE 1, 8, 9, 3

label 2
 FRM_SETON 0, 1
goto 1

label 3
 FRM_SETON 1, 1
goto 1

