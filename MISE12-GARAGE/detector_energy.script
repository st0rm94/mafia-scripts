findactor 36, "posledni_grupa_Enemy6"
findactor 37, "music"

label DETECT
wait 1000
iscarusable 24, 0
if flt[0] = 0, -1, SKIP
gosub CARISLOST

label SKIP
human_getproperty 0, 0, Energy
if flt[0] = 0, TOMMYDEATH, -1
human_getproperty 1, 0, Energy
if flt[0] = 0, PAULIEDEATH, -1
human_getproperty 2, 0, Energy
if flt[0] = 0, SAMDEATH, -1
human_getproperty 3, 0, Energy
if flt[0] = 0, -1, DETECT
human_getproperty 4, 0, Energy
if flt[0] = 0, -1, DETECT
human_getproperty 5, 0, Energy
if flt[0] = 0, -1, DETECT
human_getproperty 6, 0, Energy
if flt[0] = 0, -1, DETECT
human_getproperty 7, 0, Energy
if flt[0] = 0, -1, DETECT

if flt[6] = 0, -1, NEXT2
frm_getworldpos 3, 3
ispointinarea 3, 2, 0
if flt[0] = 0, -1, NEXT2
// Zapne skupinku v plotene ohrade
frm_seton 1, 1
act_setstate 29, active
let flt[6] = 1
// Zapne prijizdejici auto
goto SETON

label NEXT2
