human_getproperty 31, 0, Energy
if flt[0] = 0, -1, DETECT3
human_getproperty 32, 0, Energy
if flt[0] = 0, -1, DETECT3
human_getproperty 33, 0, Energy
if flt[0] = 0, -1, DETECT3
human_getproperty 35, 0, Energy
if flt[0] = 0, -1, DETECT3
human_getproperty 36, 0, Energy
if flt[0] = 0, -1, DETECT3
debug_text "detector_energy: Posledni grupa is death..."
act_setstate 22, active
act_setstate 23, active
detector_setsignal -1, 1
debug_text "detector_energy: SCRIPT FINISHED player detectors activated!"
label EVENTSAM
setevent 2, 5, EVENTSAM
label EVENTPAULIE
setevent 1, 2, EVENTPAULIE
act_setstate 37, active
let flt[2] = 1
goto DETECT2

label TOMMYDEATH
wait 2000
endofmission 0, 12980003
end
label PAULIEDEATH
endofmission 0, 12980004
end
label SAMDEATH
endofmission 0, 12980005
end
label CARISLOST
wait 3000
iscarusable 24, 0
if flt[0] = 1, -1, CARISLOST2
return
label CARISLOST2
endofmission 0, 12980000
end

label SETON
frm_seton 0, 1
act_setstate 21, active
let flt[1] = 1
goto NEXT2