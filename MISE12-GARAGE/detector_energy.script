if flt[0] = 0, -1, DETECT2
human_getproperty 28, 0, Energy
if flt[0] = 0, -1, DETECT2
//debug_text "detector_energy: Group2 is death ! Last grupa activated..."
//act_setstate 34, active
label DETECT3
wait 1000
iscarusable 24, 0
if flt[0] = 0, -1, SKIP3
gosub CARISLOST
label SKIP3
human_getproperty 0, 0, Energy
if flt[0] = 0, TOMMYDEATH, -1
human_getproperty 1, 0, Energy
if flt[0] = 0, PAULIEDEATH, -1
