dim_flt 1
dim_act 2
findactor 0, "Enemy_gr3_3"
findactor 1, "Enemy_gr3_2"
act_setstate -1, inactive

label DETECT 
wait 500
detector_inrange 0, 8
if flt[0] ! 0, -1, DETECT
commandblock 1
label SEND
setevent 0, 100, SEND
label SEND2
setevent 1, 100, SEND2
debug_text "detector_playerAUTO: Enemies forcescripted - vystoupi z auta"
commandblock 0
end