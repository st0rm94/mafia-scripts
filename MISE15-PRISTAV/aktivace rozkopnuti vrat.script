dim_flt 1
dim_act 4
dim_frm 1
findactor 0, "Delnik6"
findactor 1, "aktivace rozkopnuti vrat1"
findactor 2, "dvirkax3.Box663"
findactor 3, "dvirkax3.Box664"
findframe 0, "vrata1"

act_setstate 100, inactive

label 1
detector_inrange 0, 15
if flt[0] = 1, -1, 1

act_setstate 0, active
act_setstate 1, off
wait 500
frm_seton 0, 1
door_open 2, 1
door_open 3, 1
act_setstate 100, off