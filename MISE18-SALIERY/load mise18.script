[debug_me]
dim_flt 2
dim_act 7
findactor 0, "Vincenzo"
findactor 1, "Ralph"
findactor 2, "Tommy"
findactor 3, "GDFGEFGIJEFGEGEJGFG"
findactor 4, "detector_hlasky"
findactor 5, "Paulie"
findactor 6, "Sam"
label 1
detector_inrange 0, 4
if flt[0] = 1, -1, 1
if flt[1] = 0, 3, -1
if flt[1] = 1, 5, -1
if flt[1] = 2, 6, -1
if flt[1] = 3, 4, 1

label 3
debug_text "FIRST GO TO VINCENZO FOR WEAPONS AND TO RALPH FOR A CAR"
label SEND
setevent 4, 100, SEND
wait 6000
goto 1

label 5
debug_text "FIRST GO TO RALPH FOR CADDDDILACCCCC :)"
label SEND2
setevent 4, 100, SEND2
wait 6000
goto 1

label 6
debug_text "FIRST GO TO VINCENZO FOR WEAPONS"
label SEND3
