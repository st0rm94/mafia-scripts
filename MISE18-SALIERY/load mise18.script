wait 6000
goto 1

label 4
compareownerwithex 2, 3, 5, -1
compareownerwithex 5, 3, 1, -1
compareownerwithex 6, 3, 1, -1
commandblock 1
zatmyse 1, 1
inventory_push 2
character_push 2
