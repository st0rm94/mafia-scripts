//nahodny les6

dim_flt 2
dim_frm 1
FindFrame 0, "les6"
  soundfade 0, 2000, 0, 1
label 10
  rnd 0, 14                   
  let flt[0] = flt[0] * 600  
  let flt[0] = flt[0] + 2000  
  wait flt[0]
  soundfade 0, 3800, 1, 0.2
 rnd 1, 10                   
  let flt[1] = flt[1] * 900  
  let flt[1] = flt[1] + 2900  
  wait flt[1]
  soundfade 0, 1200, 0.2, 1
goto 10
end