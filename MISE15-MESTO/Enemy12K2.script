label 5
setevent 4, 1, 5

{ up
enemy_vidim 0
act_setstate 100, inactive
wait 100
}

event 1
enemy_look 2
enemy_wait
enemy_talk 1, 15991621, 1
enemy_playanim "chulgesto01.i3d", 0, simple
let flt[0] = flt[0] - 323
wait flt[0]
enemy_stopanim
act_setstate 4, active
return

event 2
if flt[2] = 1, 4, -1 
enemy_action_fire 2
end

label 4
wait 5000
enemy_move 1
door_lock 0, 0
door_open 0, 1
enemy_move 2, run
