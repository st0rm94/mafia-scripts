{ down
label 1
wait 7000
if flt[1] = 3, 2, -1
enemy_playanim "kurakpotahnuti.i3d", 0, simple
let flt[0] = flt[0] - 323
wait flt[0]
enemy_playanim "kurakloop.i3d"
emitparticle 0, 25
