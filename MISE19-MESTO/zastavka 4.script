dim_flt 1
dim_act 3
dim_frm 2
findactor 0, "Paulie"
findactor 1, "civil8"
findactor 2, "civil7"

findframe 0, "civil7"
findframe 1, "civil8"

act_setstate 100, inactive

label 1
wait 500
detector_inrange 0, 10
if flt[0] = 1, -1, 1

label 2
setevent 0, 2, 2

act_setstate 1, off
act_setstate 2, off
frm_seton 0, 0
frm_seton 1, 0
act_setstate 100, off