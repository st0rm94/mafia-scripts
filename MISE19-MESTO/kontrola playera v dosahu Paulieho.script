dim_flt 1
dim_act 2
findactor 0, "Tommy"
findactor 1, "Paulie"

act_setstate 100, inactive

label 1
wait 500
getactorsdist 0, 1, 0
if flt[0] > 7, -1, 1

getangleactortoactor 1, 0, 0
if flt[0] > 100, -1, 1

label 2
setevent 1, 1, 2

label 3
wait 500
getactorsdist 0, 1, 0
if flt[0] < 7, -1, 3

detector_setsignal 100, 1
goto 1