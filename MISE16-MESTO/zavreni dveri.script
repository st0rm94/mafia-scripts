dim_flt 1
dim_act 3
findactor 0, "door_dvuX"
findactor 1, "1detekce healtu playera"
findactor 2, "1detekce healtu vsech"

act_setstate 100, inactive

{ up
label 1
if flt[0] = 2, -1, 1
}

