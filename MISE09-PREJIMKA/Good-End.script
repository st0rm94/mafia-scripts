findframe 1,"Paulie"
findframe 2,"TruckA"
findframe 3,"polimTud"
findframe 4,"polimFor"
findframe 5,"Good-End"



act_setstate -1,inactive

label 101
wait 500
detector_inrange 0,10
if flt[0] = 2,-1,101


human_getproperty 2,0,Energy
if flt[0]=0,NEXT01,-1
getenemyaistate 2,0
if flt[0]=3,101,-1

label NEXT01
human_getproperty 3,0,Energy
if flt[0]=0,NEXT02,-1
