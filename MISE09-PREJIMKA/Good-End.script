if flt[0]=0,NEXT04,-1
getenemyaistate 5,0
if flt[0]=3,101,-1

label NEXT04

act_setstate 9,off
act_setstate 11,active

zatmyse 1
wait 500
commandblock 1
PLAYER_LOCKCONTROLS 1
frm_seton 0,0
frm_seton 1,0
frm_seton 2,0
act_setstate 1,off
act_setstate 6,off
loaddifferences "dif09d.chg"
