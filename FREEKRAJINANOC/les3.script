//nahodny les3

dim_flt 2
dim_frm 1
FindFrame 0, "les3"
  soundfade 0, 2000, 0, 1
label 10
  rnd 0, 12                   
  let flt[0] = flt[0] * 600  
  let flt[0] = flt[0] + 3000  
  wait flt[0]
  soundfade 0, 3000, 1, 0.2
 rnd 1, 7                   
  let flt[1] = flt[1] * 1000  
  let flt[1] = flt[1] + 4000  
  wait flt[1]
  soundfade 0, 2100, 0.2, 1
goto 10
end