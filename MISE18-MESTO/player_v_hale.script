dim_flt 2
label DETECT
wait 500
detector_inrange 0, 20
if flt[0] = 0, NOSIGNAL, SIGNAL

label NOSIGNAL
if flt[1] = 0, DETECT, -1
detector_setsignal -1, 0
let flt[1] = 0
debug_text "player_v_hale: NENI TADY !"
goto DETECT

label SIGNAL
if flt[1] = 1, DETECT, -1
detector_setsignal -1, 1
let flt[1] = 1
debug_text "player_v_hale: JE TADY !"
goto DETECT