dim_flt 2
dim_act 1
findactor 0, "Vratny"

label DETECT
wait 200
detector_inrange 0, 20
if flt[0] = 0, NOSIGNAL, SIGNAL

label NOSIGNAL
if flt[1] = 0, DETECT, -1
detector_setsignal -1, 0
let flt[1] = 0
debug_text "player_v_pristavu: NENI TADY !"
goto DETECT

label SIGNAL
if flt[1] = 1, DETECT, -1
detector_setsignal -1, 1
let flt[1] = 1
debug_text "player_v_pristavu: JE TADY !"
goto DETECT