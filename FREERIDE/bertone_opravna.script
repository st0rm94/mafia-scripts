label BEZPOLDU

compareownerwithex 0,2,101,-1
freeride_scoreget 5
if flt[5]<2000,MALO_PENEZ,-1

commandblock 1
PLAYER_LOCKCONTROLS 1
human_getowner 0,1
car_forcestop 1
actor_setplacement 1,0
car_calm 1
camera_lock 1
