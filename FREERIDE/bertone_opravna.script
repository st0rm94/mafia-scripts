findframe 0,"bertone_opravna"
findframe 1,"cam_bertone"
findframe 2,"dvere1"

let flt[1]= -707.319
let flt[2]= 5.202
let flt[3]= 87.960

frm_setpos 2,1

label 101
wait 1000
detector_inrange 0,2
if flt[0]=1,-1,101
//*****detekce poldu
policeitchforplayer 0
if flt[0]>0,-1,BEZPOLDU
if flt[6]=0,-1,101
human_talk 0,00950072
let flt[6]=1
