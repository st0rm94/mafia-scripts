label 102
getticktime 4
let flt[4]=flt[4]*0.004
let flt[2]=flt[2]-flt[4]
if flt[2]<2.517,CLOSE,-1
commandblock 0
frm_setpos 2,1
commandblock 1
goto 102
label CLOSE
