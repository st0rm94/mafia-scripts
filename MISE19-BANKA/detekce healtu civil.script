dim_flt 1
dim_act 3
findactor 0, "civil"
findactor 1, "BnkO"
findactor 2, "Tommy"

label 1
wait 1000
human_getproperty 0, 0, energy
if flt[0] < 100, -1, 1

getactorsdist 1, 2, 0
if flt[0] < 5, 2, -1

detector_inrange 0, 15
if flt[0] = 1, -1, 3

label 2
setevent 1, 3, -1

label 3
act_setstate 100, off

