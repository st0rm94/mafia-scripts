act_setstate -1, inactive
dim_act 1
dim_flt 1
findactor 0, "Sara"
label HLASKA
rnd 0, 3
let flt[0] = flt[0] + 1
goto flt[0]
label 1
human_talk 0, 07990201, 1
goto WAIT
label 2
